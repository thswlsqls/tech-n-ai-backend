###
# POST /api/v1/auth/admin/login - 관리자 로그인 실패 제한 테스트
# Description: 5회/10회 실패 시 계정 잠금 동작 확인
# @no-cookie-jar
###

### 1. 로그인 실패 1회차
POST {{gatewayUrl}}/api/v1/auth/admin/login
Content-Type: application/json

{
  "email": "{{adminEmail}}",
  "password": "wrong-password-1"
}

> {%
    client.test("로그인 실패 1회차", function() {
        client.assert(response.status === 401, "응답 상태 코드가 401이어야 합니다");
    });
%}

