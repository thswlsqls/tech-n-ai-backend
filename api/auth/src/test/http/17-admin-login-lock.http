### 5. 로그인 실패 5회차 - 계정 잠금 트리거
POST {{gatewayUrl}}/api/v1/auth/admin/login
Content-Type: application/json

{
  "email": "{{adminEmail}}",
  "password": "wrong-password-5"
}

> {%
    client.test("로그인 실패 5회차 - 계정 잠금 트리거", function() {
        client.assert(response.status === 401, "응답 상태 코드가 401이어야 합니다");
    });
%}

### 6. 잠금 상태에서 올바른 비밀번호로 로그인 시도
POST {{gatewayUrl}}/api/v1/auth/admin/login
Content-Type: application/json

{
  "email": "{{adminEmail}}",
  "password": "{{adminPassword}}"
}

> {%
    client.test("계정 잠금 상태 - 올바른 비밀번호도 거부", function() {
        client.assert(response.status === 401, "응답 상태 코드가 401이어야 합니다 (계정 잠김)");
    });
%}
